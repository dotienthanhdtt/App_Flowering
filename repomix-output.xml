  }

  Widget _buildBackground() {
    if (scenario.imageUrl != null && scenario.imageUrl!.isNotEmpty) {
      return Image.network(
        scenario.imageUrl!,
        fit: BoxFit.cover,
        errorBuilder: (_, e, s) => _PlaceholderBg(scenario: scenario),
